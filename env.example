# ── Required ──────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=your_notification_channel_id
DISCORD_GUILD_ID=your_discord_server_id

# ── Optional ──────────────────────────────────────────────────────────────
# How often to check each account (milliseconds). Default: 12000 (12 seconds)
CHECK_INTERVAL_MS=12000

# ── Railway Volume (IMPORTANT for Railway deployment) ─────────────────────
# In Railway: add a Volume mounted at /data, then set this variable to /data
# This ensures your monitoring_base.json, old_clients.json, and permissions.json
# survive deploys and restarts. Without this, all data resets on every deploy!
DATA_DIR=/data
