# ── Required ───────────────────────────────────────────────────────────────
# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# The channel ID where ban/unban alerts will be sent
DISCORD_CHANNEL_ID=your_notification_channel_id

# Your Discord server (guild) ID
DISCORD_GUILD_ID=your_discord_server_id

# ── Optional ────────────────────────────────────────────────────────────────
# How often to check each account (milliseconds). Default: 12000 (12 seconds)
# Lower = faster detection but higher chance of getting rate limited by Instagram
CHECK_INTERVAL_MS=12000

# HTTP/HTTPS proxy URL to route Instagram requests through.
# Strongly recommended on Railway to avoid IP bans from Instagram.
# Format: http://username:password@host:port
# PROXY_URL=http://user:pass@proxyhost:port

# ── Railway Volume (IMPORTANT for Railway deployment) ──────────────────────
# In Railway: add a Volume mounted at /data, then set this variable to /data
# This ensures monitoring_base.json, old_clients.json, and permissions.json
# survive deploys and restarts. Without this, ALL data resets on every deploy!
DATA_DIR=/data
